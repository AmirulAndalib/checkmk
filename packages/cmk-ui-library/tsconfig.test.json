{
  "extends": "./tsconfig.vue-base.json",
  "include": ["env.d.ts", "weaki18nString.d.ts", "lib/**/*", "components/**/*", "tests/**/*"],
  // i18nString.ts strongly types TranslatedString; tests use the weak variant
  // mapped in via weaki18nString.d.ts below.
  "exclude": ["lib/i18nString.ts"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "baseUrl": ".",
    "paths": {
      "@/lib/i18nString": ["./weaki18nString.d.ts"],
      "@/lib/*": ["./lib/*"],
      "@/components/*": ["./components/*"],
      "cmk-ui-library/*": ["./*"],
      "*": ["./node_modules/*", "../../bazel-bin/packages/cmk-ui-library/node_modules/*"]
    }
  }
}
