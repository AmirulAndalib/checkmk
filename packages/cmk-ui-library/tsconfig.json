{
  "extends": "./tsconfig.vue-base.json",
  "include": ["env.d.ts", "lib/**/*", "components/**/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      // Self-references: package files import each other as `cmk-ui-library/...`,
      // exactly like consumers do, so files can move between the package and
      // its consumers without import rewrites.
      "cmk-ui-library/*": ["./*"],
      "*": ["./node_modules/*", "../../bazel-bin/packages/cmk-ui-library/node_modules/*"]
    }
  }
}
