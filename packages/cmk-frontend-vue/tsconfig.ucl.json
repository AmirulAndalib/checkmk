{
  "extends": "./tsconfig.app.json",
  "include": [
    "env.d.ts",
    "weaki18nString.d.ts",
    "src/**/*",
    "ui-component-library/**/*",
    "ui-component-library/**/*.vue"
  ],
  "exclude": ["src/lib/i18nString.ts"],
  "compilerOptions": {
    "types": ["node"],
    "paths": {
      "@/lib/i18nString": ["weaki18nString.d.ts"],
      "@/lib/*": [
        "./node_modules/cmk-ui-library/lib/*",
        "../../bazel-bin/packages/cmk-frontend-vue/node_modules/cmk-ui-library/lib/*"
      ],
      "@/components/*": [
        "./node_modules/cmk-ui-library/components/*",
        "../../bazel-bin/packages/cmk-frontend-vue/node_modules/cmk-ui-library/components/*"
      ],
      "@/*": ["./src/*"],
      "@ucl/*": ["./ui-component-library/*"],
      "*": ["./node_modules/*", "../../bazel-bin/packages/cmk-frontend-vue/node_modules/*"]
    }
  }
}
