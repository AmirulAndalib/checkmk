{
  // Compiler options shared by all Checkmk Vue packages live in cmk-ui-library's base
  // config; this file only owns this package's project shape.
  "extends": "cmk-ui-library/tsconfig.vue-base.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@ucl/*": ["./ui-component-library/*"],
      "*": ["./node_modules/*", "../../bazel-bin/packages/cmk-frontend-vue/node_modules/*"]
    }
  }
}
