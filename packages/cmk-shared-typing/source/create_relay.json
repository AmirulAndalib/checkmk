{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "type": "object",
  "title": "Create relay",
  "properties": {
    "urls": {
      "type": "object",
      "properties": {
        "create_host": {
          "type": "string"
        },
        "relay_overview": {
          "type": "string"
        },
        "documentation": {
          "type": "string"
        }
      },
      "required": ["create_host", "relay_overview", "documentation"]
    },
    "site_name": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "agent_receiver_port": {
      "type": "integer"
    },
    "site_version": {
      "type": "string"
    },
    "supported_os": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "server_port": {
      "type": ["integer", "null"]
    },
    "exp_add_windows_relay_enabled": {
      "type": "boolean",
      "description": "When true, show the OS selector to allow registering a Windows relay."
    }
  },
  "required": ["urls", "site_name", "domain", "agent_receiver_port", "site_version", "supported_os"]
}
